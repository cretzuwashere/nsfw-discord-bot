<%- include('partials/head') %>
<%- include('partials/nav') %>
<h1>Audit Logs</h1>

<section class="card">
  <form method="get" action="/audit-logs" class="filter-form">
    <label for="action">Filter by action</label>
    <input id="action" name="action" type="search" placeholder="e.g. admin.login" value="<%= action %>">
    <button type="submit" class="btn btn-ghost">Filter</button>
    <% if (action) { %><a class="btn btn-ghost" href="/audit-logs">Clear</a><% } %>
  </form>

  <% if (rows.length === 0) { %>
    <p class="muted">No audit entries<%= action ? ' matching that action' : '' %>.</p>
  <% } else { %>
    <table>
      <thead><tr><th>Time</th><th>Actor</th><th>Action</th><th>Guild</th><th>Target</th><th>Metadata</th></tr></thead>
      <tbody>
        <% for (const row of rows) { %>
          <tr>
            <td class="nowrap"><%= row.createdAt.toISOString().replace('T', ' ').slice(0, 19) %></td>
            <td><%= row.actorType %><% if (row.actorId) { %> <span class="muted small"><%= row.actorId %></span><% } %></td>
            <td><code><%= row.action %></code></td>
            <td><%= row.guildId ?? '—' %></td>
            <td><%= row.targetType ? `${row.targetType}:${row.targetId ?? ''}` : '—' %></td>
            <td class="muted small"><%= row.metadataText %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  <% } %>

  <div class="pagination">
    <span class="muted small"><%= total %> entries · page <%= page %></span>
    <% if (page > 1) { %>
      <a class="btn btn-ghost" href="/audit-logs?page=<%= page - 1 %><%= action ? `&action=${encodeURIComponent(action)}` : '' %>">« Previous</a>
    <% } %>
    <% if (hasNext) { %>
      <a class="btn btn-ghost" href="/audit-logs?page=<%= page + 1 %><%= action ? `&action=${encodeURIComponent(action)}` : '' %>">Next »</a>
    <% } %>
  </div>
</section>
<%- include('partials/footer') %>
