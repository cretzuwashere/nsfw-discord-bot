<%- include('partials/head') %>
<%- include('partials/nav') %>
<h1>Dynamic Cards</h1>
<% if (message) { %><div class="alert alert-ok" role="status"><%= message.replace(/\+/g, ' ') %></div><% } %>

<section class="card">
  <p><a class="btn btn-primary" href="/cards/new">New template</a></p>
  <% if (templates.length === 0) { %>
    <p class="muted">No card templates yet. Create one to generate welcome cards, birthday cards or banners.</p>
  <% } else { %>
    <table>
      <thead><tr><th>Name</th><th>Kind</th><th>Size</th><th>Preview</th><th></th></tr></thead>
      <tbody>
        <% for (const t of templates) { %>
          <tr>
            <td><a href="/cards/<%= t.id %>"><%= t.name %></a></td>
            <td><%= t.kind %></td>
            <td class="muted small"><%= t.width %>×<%= t.height %></td>
            <td><img src="/cards/<%= t.id %>/preview.png" alt="preview" style="max-height:60px;border-radius:6px"></td>
            <td>
              <form method="post" action="/cards/<%= t.id %>/archive" class="inline-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-warn">Archive</button>
              </form>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  <% } %>
</section>

<section class="card">
  <h2>Background images</h2>
  <form method="post" action="/cards/upload" enctype="multipart/form-data">
    <label for="file">Upload a background (PNG, JPEG or WebP, max 8&nbsp;MB)</label>
    <input id="file" name="file" type="file" accept="image/png,image/jpeg,image/webp">
    <button type="submit" class="btn btn-primary">Upload</button>
  </form>
  <% if (assets.length > 0) { %>
    <table>
      <thead><tr><th>Asset ID</th><th>Name</th><th>Type</th><th>Size</th></tr></thead>
      <tbody>
        <% for (const a of assets) { %>
          <tr>
            <td><code><%= a.id %></code></td>
            <td><%= a.originalName %></td>
            <td class="muted small"><%= a.mimeType %></td>
            <td class="muted small"><%= Math.round(a.byteSize / 1024) %> KB</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  <% } %>
</section>
<%- include('partials/footer') %>
