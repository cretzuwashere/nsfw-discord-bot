# Hoisted node_modules layout: a single flat node_modules at the repo root.
# Chosen so Docker only needs ONE named volume for dependencies, avoiding
# symlink problems on Windows bind mounts. See docs/ASSUMPTIONS.md.
node-linker=hoisted

# Reproducible installs in CI and Docker.
prefer-frozen-lockfile=true

# Workspace packages are always linked from source.
link-workspace-packages=true
