# ============================================================================
# Bot Platform — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All services read these variables via Docker Compose.
# ============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# --- Database ----------------------------------------------------------------
# Inside Docker the host is the compose service name `db`.
POSTGRES_USER=botplatform
POSTGRES_PASSWORD=change_me_dev_password
POSTGRES_DB=botplatform
DATABASE_URL=postgres://botplatform:change_me_dev_password@db:5432/botplatform

# --- Discord (get these from https://discord.com/developers/applications) ----
# Leave empty to run the platform without a Discord connection (admin panel,
# tests and health checks all still work).
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# --- Admin panel ---------------------------------------------------------------
ADMIN_PORT=3000
PUBLIC_ADMIN_URL=http://localhost:3000
# Session encryption secret: at least 32 characters, random.
# Generate inside Docker:  docker compose exec app node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_string_of_at_least_32_chars
# Set to "true" behind HTTPS in production.
COOKIE_SECURE=false

# --- Admin bootstrap user (created by `pnpm db:seed` if it does not exist) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password

# --- Bot worker ----------------------------------------------------------------
# Port for the bot's health endpoint + internal status API (Docker network only).
HEALTH_PORT=8081
# Shared secret between admin panel and bot worker for the internal API.
INTERNAL_API_TOKEN=change_me_internal_token
# Hostname where the admin panel can reach the bot's internal API.
BOT_INTERNAL_URL=http://bot:8081

# --- Audio module --------------------------------------------------------------
# Comma-separated domain allowlist for audio URLs. Empty = any public domain.
ALLOWED_AUDIO_DOMAINS=
MAX_QUEUE_SIZE=50
MAX_TRACK_DURATION_SECONDS=3600
AUDIO_REQUEST_TIMEOUT_MS=15000

# --- E2E tests (Playwright) ----------------------------------------------------
E2E_ADMIN_EMAIL=e2e-admin@example.com
E2E_ADMIN_PASSWORD=e2e_test_password_123
PLAYWRIGHT_BASE_URL=http://admin:3000
